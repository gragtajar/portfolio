# ============================================================================
# rajatg.in — Apache configuration (cPanel)
# Security headers + cache control + clean URLs
# ============================================================================

# Force HTTPS
<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteCond %{HTTPS} !=on
  RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

  # Strip .html extension (optional clean URLs)
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteCond %{REQUEST_FILENAME}\.html -f
  RewriteRule ^([^\.]+)$ $1.html [NC,L]
</IfModule>

# ----------------------------------------------------------------------------
# Security headers
# ----------------------------------------------------------------------------
<IfModule mod_headers.c>
  # Prevent MIME-type sniffing
  Header set X-Content-Type-Options "nosniff"

  # Prevent clickjacking
  Header set X-Frame-Options "DENY"

  # Control Referer information
  Header set Referrer-Policy "strict-origin-when-cross-origin"

  # Disable unused browser features
  Header set Permissions-Policy "camera=(), microphone=(), geolocation=(), interest-cohort=()"

  # Enable HSTS (only after SSL is verified working — 1 year, includes subdomains)
  Header set Strict-Transport-Security "max-age=31536000; includeSubDomains"

  # Content Security Policy — permissive for the resources the site uses
  # Allows: self origin, Google Fonts, TMDB images, Lottie CDN, canvas-confetti CDN, inline scripts/styles
  Header set Content-Security-Policy "default-src 'self'; script-src 'self' 'unsafe-inline' https://unpkg.com https://cdn.jsdelivr.net; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; img-src 'self' data: https://image.tmdb.org; font-src 'self' https://fonts.gstatic.com; connect-src 'self' https://api.themoviedb.org https://fonts.gstatic.com; frame-ancestors 'none'; base-uri 'self'; form-action 'self'"
</IfModule>

# ----------------------------------------------------------------------------
# Cache headers per file type
# ----------------------------------------------------------------------------
<IfModule mod_expires.c>
  ExpiresActive On

  # HTML — short cache so updates propagate quickly
  ExpiresByType text/html "access plus 5 minutes"

  # CSS / JS — 30 days (change filenames when bumping)
  ExpiresByType text/css "access plus 30 days"
  ExpiresByType application/javascript "access plus 30 days"
  ExpiresByType text/javascript "access plus 30 days"

  # Images — 1 year
  ExpiresByType image/jpeg "access plus 1 year"
  ExpiresByType image/png "access plus 1 year"
  ExpiresByType image/webp "access plus 1 year"
  ExpiresByType image/avif "access plus 1 year"
  ExpiresByType image/svg+xml "access plus 1 year"
  ExpiresByType image/x-icon "access plus 1 year"
  ExpiresByType image/vnd.microsoft.icon "access plus 1 year"

  # Fonts — 1 year
  ExpiresByType font/woff2 "access plus 1 year"
  ExpiresByType font/woff "access plus 1 year"
  ExpiresByType application/font-woff2 "access plus 1 year"

  # JSON data — 1 day (movies.json updates occasionally)
  ExpiresByType application/json "access plus 1 day"
  ExpiresByType application/manifest+json "access plus 7 days"

  # XML (sitemap) — 1 day
  ExpiresByType application/xml "access plus 1 day"
  ExpiresByType text/xml "access plus 1 day"
</IfModule>

<IfModule mod_headers.c>
  # Mark fonts and long-cached static assets as immutable
  <FilesMatch "\.(woff2|woff|ttf|eot|otf)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>
  <FilesMatch "\.(jpg|jpeg|png|webp|avif|svg|ico)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>
  <FilesMatch "\.(css|js)$">
    Header set Cache-Control "public, max-age=2592000"
  </FilesMatch>
  <FilesMatch "\.html$">
    Header set Cache-Control "public, max-age=300, must-revalidate"
  </FilesMatch>
  <FilesMatch "\.(json)$">
    Header set Cache-Control "public, max-age=86400"
  </FilesMatch>
</IfModule>

# ----------------------------------------------------------------------------
# Compression
# ----------------------------------------------------------------------------
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/css text/javascript application/javascript application/json application/xml text/xml image/svg+xml application/manifest+json text/plain
</IfModule>

# ----------------------------------------------------------------------------
# Custom MIME types
# ----------------------------------------------------------------------------
<IfModule mod_mime.c>
  AddType image/svg+xml .svg
  AddType image/webp .webp
  AddType image/avif .avif
  AddType application/manifest+json .webmanifest
  AddType font/woff2 .woff2
</IfModule>

# ----------------------------------------------------------------------------
# Disable directory listing
# ----------------------------------------------------------------------------
Options -Indexes

# Block hidden files (dotfiles)
<FilesMatch "^\.">
  Require all denied
</FilesMatch>

# Block sensitive files
<FilesMatch "\.(md|spec|env|log|sql|bak|swp|orig)$">
  Require all denied
</FilesMatch>

# ----------------------------------------------------------------------------
# Custom error pages (optional — point to existing pages if 404.html exists)
# ----------------------------------------------------------------------------
# ErrorDocument 404 /404.html
